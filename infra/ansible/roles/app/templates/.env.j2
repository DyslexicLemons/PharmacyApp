# PharmacyApp environment — generated by Ansible, do not edit manually.
# Source of truth: infra/ansible/roles/app/templates/.env.j2

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@postgres:5432/{{ db_name }}

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY={{ jwt_secret_key }}

# ── CORS ──────────────────────────────────────────────────────────────────────
# Adjust if you're terminating TLS upstream and the frontend uses https://
ALLOWED_ORIGINS=http://{{ ansible_host }},http://localhost

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Debug ─────────────────────────────────────────────────────────────────────
# Set to "false" in production to reduce log volume
LOG_RX_DEBUG=false
