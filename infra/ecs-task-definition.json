{
  "family": "pharmacy-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/pharmacyTaskRole",
  "containerDefinitions": [
    {
      "name": "pharmacy-backend",
      "image": "ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/pharmacy-backend:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "AWS_SECRET_NAME", "value": "pharmacy/prod" },
        { "name": "AWS_REGION",      "value": "us-east-1"     },
        { "name": "UPLOAD_DIR",      "value": "/app/uploads"  }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/pharmacy-backend",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      },
      "essential": true
    }
  ]
}
