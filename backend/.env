# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:6789@localhost/pharmacy_db

# JWT secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=b423325768eb67fe7e030642e7ec4528e783add4e12018bc53307d2993c652ae

# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173

# Directory for uploaded prescription images (relative to backend root or absolute)
UPLOAD_DIR=uploads
