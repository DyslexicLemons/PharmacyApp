# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost/pharmacy_db

# JWT secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<your-secret-key-here>

# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173

# Directory for uploaded prescription images (relative to backend root or absolute)
UPLOAD_DIR=uploads
