# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost/pharmacy_db

# JWT secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<your-secret-key-here>

# Comma-separated list of allowed frontend origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173

# Directory for uploaded prescription images (relative to backend root or absolute)
UPLOAD_DIR=uploads

# Redis connection string (optional — falls back to database if not set)
REDIS_URL=redis://localhost:6379

# Secret used to HMAC-mask patient IDs in server logs (keeps PHI out of CloudWatch).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LOG_SALT=<your-log-salt-here>

# Set to "true" to enable DEBUG-level logging for pharmacy.rx (stale-queue checks,
# cache hit/miss details for GET /refills/{id}).  Off by default — for local debugging only.
LOG_RX_DEBUG=false

# VPC CIDR of the Application Load Balancer. When set, the rate limiter reads the
# real client IP from X-Forwarded-For instead of the TCP peer (which is always the
# ALB behind ECS). Leave unset in local dev — the TCP peer is used directly.
# Example: ALB_TRUSTED_CIDR=10.0.0.0/16
ALB_TRUSTED_CIDR=
