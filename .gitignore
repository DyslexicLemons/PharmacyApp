# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# Node / frontend
node_modules/
dist/
.cache/

# Uploads
backend/uploads/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Terraform — never commit state or secrets
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/terraform.tfvars
infra/*.tfplan

# Terraform bootstrap — local state is intentional here; lock file is machine-specific
infra/bootstrap/.terraform/
infra/bootstrap/.terraform.lock.hcl

# Ansible — inventory contains real IPs and credentials
infra/ansible/inventory/hosts.ini
